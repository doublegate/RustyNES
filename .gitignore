# =============================================================================
# .gitignore — RustyNES
# (negations `!` must follow the broad rule they re-include — order matters)
# =============================================================================

# --- Rust / Cargo ---
/target/
/target/doc/
/target/criterion/
**/*.rs.bk
*.bench
# This workspace ships a binary app — commit the lock (re-include it).
Cargo.lock
!/Cargo.lock

# --- Native build & FFI artifacts ---
*.so
*.dylib
*.dll
*.exe
*.a
*.lib
*.pdb

# --- WebAssembly / trunk / wasm-pack ---
/pkg/
/dist/
*.wasm
wasm-pack.log
# trunk build output (regenerated by `trunk build`; never committed).
/crates/rustynes-frontend/web/dist/
# v1.5.0 Workstream G — the Emscripten rcheevos→wasm side module
# (`scripts/cheevos/build_rcheevos_wasm.sh` output). The `.wasm` (above) +
# `.js` glue are build artifacts: rebuild on demand, never commit. The hand-
# written loader (`ra_glue.js`) + the dir's README ARE committed.
/crates/rustynes-frontend/web/cheevos/rcheevos.js

# --- Node.js (web frontend) ---
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# --- Python (helper scripts under scripts/, icon generator under assets/) ---
__pycache__/
*.pyc
.venv/
venv/
# Icon generator default output dir (regenerated by make_icon.py).
/assets/RustyNES_Icon/out/

# --- Platform packages ---
*.AppImage
*.snap
*.flatpak
*.msi
*.appx
# insta reference snapshots also end in `.snap`; the ROM suites compare against
# these committed fixtures, so re-include them (overrides the Snapcraft `*.snap`).
!**/snapshots/**/*.snap
!**/snapshots/*.snap

# --- Fuzzing (commit the harnesses; ignore the build/corpus) ---
fuzz/
!/fuzz/
/fuzz/target/
/fuzz/corpus/
/fuzz/artifacts/
/fuzz/coverage/
corpus/
artifacts/

# --- ROMs & media (copyright) ---
# The broad `*.nes`/`*.fds` rules ignore ALL ROMs; re-include the committable
# CC0 / public-domain suites under tests/roms/, then HARD-exclude the commercial
# dumps + the large fetched clone (NEVER committed — Nintendo copyright).
*.nes
*.fds
!/tests/roms/**/*.nes
/tests/roms/external/
/tests/roms/nes-test-roms/
/game-roms/
*.qd
*.nsf
*.nsfe
*.nsf2
# User-supplied palette files (v1.1.0 .pal loading) — none committed
*.pal
# ROM soft-patches (v1.2.0 ingest: auto-applied .ips/.ups/.bps beside a ROM).
# User-supplied, copyright-adjacent — never committed (mirrors the ROM policy).
*.ips
*.ups
*.bps

# --- TAS movie files (may contain copyrighted content) ---
*.fm2
*.fm3
*.bk2
*.tasproj

# --- Save / state / input / dumps / cheats ---
*.sav
*.srm
*.state
*.savestate
*.snapshot
*.quick*.state
*.rec
*.input
*.ram
*.dump
*.cht

# --- Game database files ---
*.dat
*.xml
!assets/**/*.xml
# v1.2.0 in-app ROM-Database editor writes a user overlay to the OS data dir;
# ignore a stray copy if the app is ever run from the repo root.
game_db_user.txt

# --- Logs / debug / test output ---
*.log
# Keep the kevtris nestest golden trace despite the broad *.log ignore.
!/tests/roms/nestest/nestest.log
*.test.log
*.golden
test-output/
/tests/captures/
/tests/framework/enhanced-validator/target/
/tests/framework/*.exe
/tests/framework/test_rom_validator

# --- Coverage / profiling ---
*.gcno
*.gcda
coverage/
tarpaulin-report.html
perf.data
perf.data.old
flamegraph.svg
/perf-logs/
# PGO / profile-guided-optimization artifacts (v1.2.0 pgo.yml + scripts/pgo/).
# The instrument/train profiles are regenerated by the recipe; never committed.
*.profraw
*.profdata
/pgo-data/
/target/pgo/

# --- Documentation (build output + local-only references) ---
/docs/_site/
# Engine-development audit history (the C1 IRQ saga, DMA investigations, the
# v2.0 promotion logs, ...) — kept locally, NOT in the public repo. The v1.0.0
# synthesis handoff lives at docs/v1.0.0-synthesis-handoff-*.md instead.
/docs/audit/
# Large local NESdev wiki mirror (~208M, reference only).
/nesdev_wiki/

# --- Reference projects (external cloned repos) ---
/ref-proj/

# --- Temporary files ---
/tmp/
/temp/
*.tmp

# --- Environment ---
.env
.env.local

# --- Editors ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
._*
Thumbs.db

# --- Pre-commit ---
.pre-commit-cache/

# --- AI assistant local files ---
GEMINI.md
CLAUDE.local.md
/.claude/
WARP.md
/.warp/

# v1.3.0 D1 — BestEffort boot-smoke ROM staging (homebrew/unlicensed/multicart;
# never committed, like tests/roms/external/). Only screenshots are committed.
tests/roms/external-besteffort/
