# =============================================================================
# .gitignore — RustyNES
# (negations `!` must follow the broad rule they re-include — order matters)
# =============================================================================

# --- Rust / Cargo ---
/target/
/target/doc/
/target/criterion/
**/*.rs.bk
*.bench
# This workspace ships a binary app — commit the lock (re-include it).
Cargo.lock
!/Cargo.lock

# --- Native build & FFI artifacts ---
*.so
*.dylib
*.dll
*.exe
*.a
*.lib
*.pdb

# --- WebAssembly / trunk / wasm-pack ---
/pkg/
/dist/
*.wasm
wasm-pack.log
# trunk build output (regenerated by `trunk build`; never committed).
/crates/rustynes-frontend/web/dist/
# v1.5.0 Workstream G — the Emscripten rcheevos→wasm side module
# (`scripts/cheevos/build_rcheevos_wasm.sh` output). The `.wasm` (above) +
# `.js` glue are build artifacts: rebuild on demand, never commit. The hand-
# written loader (`ra_glue.js`) + the dir's README ARE committed.
/crates/rustynes-frontend/web/cheevos/rcheevos.js

# --- Node.js (web frontend) ---
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# --- Python (helper scripts under scripts/, icon generator under assets/) ---
__pycache__/
*.pyc
.venv/
venv/
# Icon generator default output dir (regenerated by make_icon.py).
/assets/RustyNES_Icon/out/

# --- Platform packages ---
*.AppImage
*.snap
*.flatpak
*.msi
*.appx
# insta reference snapshots also end in `.snap`; the ROM suites compare against
# these committed fixtures, so re-include them (overrides the Snapcraft `*.snap`).
!**/snapshots/**/*.snap
!**/snapshots/*.snap
# ...but insta's pending/rejected snapshots (`.snap.new`) are transient — accept
# them into `.snap` (`cargo insta accept`) or delete; never commit.
*.snap.new

# --- Fuzzing (commit the harnesses; ignore the build/corpus) ---
fuzz/
!/fuzz/
/fuzz/target/
/fuzz/corpus/
/fuzz/artifacts/
/fuzz/coverage/
corpus/
artifacts/

# --- ROMs & media (copyright) ---
# The broad `*.nes`/`*.fds` rules ignore ALL ROMs; re-include the committable
# CC0 / public-domain suites under tests/roms/, then HARD-exclude the commercial
# dumps + the large fetched clone (NEVER committed — Nintendo copyright).
*.nes
*.fds
!/tests/roms/**/*.nes
/tests/roms/external/
/tests/roms/nes-test-roms/
/game-roms/

# coverage tool's cached library-header scan (developer-local; ~25k headers)
/scripts/coverage/.library-index.json
*.qd
*.nsf
*.nsfe
*.nsf2
# User-supplied palette files (v1.1.0 .pal loading) — none committed
*.pal
# ROM soft-patches (v1.2.0 ingest: auto-applied .ips/.ups/.bps beside a ROM).
# User-supplied, copyright-adjacent — never committed (mirrors the ROM policy).
*.ips
*.ups
*.bps

# --- TAS movie files (may contain copyrighted content) ---
*.rnm
*.rnmproj
*.rnmb
*.fm2
*.fm3
*.bk2
*.tasproj

# --- Save / state / input / dumps / cheats ---
*.rns
*.sav
*.srm
*.state
*.savestate
*.snapshot
*.quick*.state
*.rec
*.input
*.ram
*.dump
*.cht

# --- Game database files ---
*.db
*.sqlite
*.dat
*.xml
!assets/**/*.xml
# v1.2.0 in-app ROM-Database editor writes a user overlay to the OS data dir;
# ignore a stray copy if the app is ever run from the repo root.
game_db_user.txt

# --- Logs / debug / test output ---
*.log
# Keep the kevtris nestest golden trace despite the broad *.log ignore.
!/tests/roms/nestest/nestest.log
*.test.log
*.golden
test-output/
/tests/captures/
/tests/framework/enhanced-validator/target/
/tests/framework/*.exe
/tests/framework/test_rom_validator

# --- Coverage / profiling ---
*.gcno
*.gcda
coverage/
# ...but NOT the committed coverage tooling (the `coverage/` rule above is for
# code-coverage artifact dirs; the cache JSON stays ignored via its rule above).
!/scripts/coverage/
!/scripts/coverage/**
/scripts/coverage/.library-index.json
/scripts/coverage/__pycache__/
tarpaulin-report.html
perf.data
perf.data.old
flamegraph.svg
/perf-logs/
# PGO / profile-guided-optimization artifacts (v1.2.0 pgo.yml + scripts/pgo/).
# The instrument/train profiles are regenerated by the recipe; never committed.
*.profraw
*.profdata
/pgo-data/
/target/pgo/

# --- Documentation (build output + local-only references) ---
/docs/_site/
# Engine-development audit history (the C1 IRQ saga, DMA investigations, the
# v2.0 promotion logs, ...) — kept locally, NOT in the public repo. The v1.0.0
# synthesis handoff lives at docs/v1.0.0-synthesis-handoff-*.md instead.
/docs/audit/
# Large local NESdev wiki mirror (~208M, reference only).
/nesdev_wiki/

# --- Reference projects (external cloned repos) ---
/ref-proj/

# --- Temporary files ---
/tmp/
/temp/
*.tmp

# --- Merge / patch artifacts (git conflict + `git apply --reject` leftovers) ---
*.orig
*.rej

# --- Environment ---
.env
.env.local

# --- Editors ---
.idea/
.vscode/
.zed/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
._*
Thumbs.db
Desktop.ini

# --- Android (v1.8.0) ---
# The android/ Gradle module has its own .gitignore (build/, .gradle/, jniLibs/,
# keystore.properties, local.properties, the wrapper jar); these belt-and-suspenders
# rules cover the same outputs if a tool scans from the repo root. The committed
# Gradle wrapper (gradlew[.bat] + gradle-wrapper.jar) and keystore.properties.example
# are intentionally tracked.
android/**/build/
**/.gradle/
android/local.properties
android/keystore.properties
*.jks
*.keystore
android/app/src/main/jniLibs/

# --- iOS (v1.9.0 "Sunrise") ---
# The xcframework + the UniFFI-generated Swift surface + the XcodeGen-generated
# Xcode project are all BUILD ARTIFACTS (regenerated by
# scripts/build-ios-xcframework.sh); never committed. The hand-written SwiftUI
# sources, project.yml, Info.plist, entitlements, PrivacyInfo, the bridging
# header, and ios/Generated/.gitkeep ARE tracked.
ios/RustyNESFFI.xcframework/
ios/Generated/RustyNESCore.swift
ios/RustyNES.xcodeproj/
ios/build/
*.ipa
# fastlane local output (the generated docs + the last-run report).
fastlane/report.xml
fastlane/README.md
fastlane/test_output/

# --- Pre-commit ---
.pre-commit-cache/

# --- AI assistant local files ---
GEMINI.md
CLAUDE.local.md
/.claude/
WARP.md
/.warp/

# Local scratch / salvage working dir (data/docs/logs pulled from /tmp triage); not
# part of the repo.
/salvaged/

# NOTE: BestEffort boot-smoke ROMs (homebrew/unlicensed/multicart) are no longer
# a separate tree — they live under the already-ignored tests/roms/external/
# alongside every other staged dump (the coverage harness discovers ONE external/
# ROM tree; only the *screenshots* are tier-split, into screenshots/besteffort/).
