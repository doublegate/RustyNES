# RustyNES browser-netplay deploy — environment template.
#
# Copy to `.env` in this directory and substitute real values, then:
#   docker compose up --build -d
# docker compose auto-loads `.env` from the compose-file directory. `.env` is
# gitignored; this `.env.example` is the committed template. All values below are
# CLEARLY-PLACEHOLDER — replace them with your own host/domain/secret.

# Public hostname Caddy serves wss:// on. `localhost` uses Caddy's internal
# self-signed CA (local two-tab test); a real domain triggers automatic
# Let's Encrypt issuance (also drop `tls internal` from the Caddyfile then).
DOMAIN=signaling.example.com

# coturn TURN long-term credential (username:secret). CHANGE THE SECRET for any
# real deploy — `changeme` is a placeholder, not a usable credential.
TURN_USER=rustynes
TURN_SECRET=changeme

# Realm coturn advertises to TURN clients — set to your domain for a real deploy.
TURN_REALM=signaling.example.com
