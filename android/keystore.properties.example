# Play App Signing UPLOAD key for the release build.
#
# Copy this file to `android/keystore.properties` (gitignored) and fill in the
# values for your upload keystore. When the real file is absent, the release
# build still links but stays UNSIGNED (CI bundles an unsigned AAB for the
# link/alignment check). Play manages the actual app signing key; this is only
# the upload key.
#
# Create an upload keystore with:
#   keytool -genkeypair -v -keystore upload.jks -keyalg RSA -keysize 2048 \
#     -validity 10000 -alias rustynes-upload
#
storeFile=/absolute/path/to/upload.jks
storePassword=CHANGEME
keyAlias=rustynes-upload
keyPassword=CHANGEME
