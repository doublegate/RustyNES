    <!-- ===== Play Games project id (Workstream D+E) =====
         PLACEHOLDER. The Play Games SDK requires the linked project's numeric app id in
         the manifest (<meta-data com.google.android.gms.games.APP_ID>). The maintainer
         creates the Play Games Services project in the Play Console and replaces "0"
         with the generated numeric id (the games-ids.xml value). "0" is intentionally
         not a valid project id, so PGS sign-in fails closed until then — belt-and-
         suspenders on top of the default-off BuildConfig.PGS_ENABLED flag. Marked
         translatable="false" (a numeric id, never localized). -->
    <string name="game_services_project_id" translatable="false">0</string>

