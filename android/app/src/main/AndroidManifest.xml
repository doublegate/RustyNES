<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Hardware gamepads are supported but not required; the on-screen touch
         overlay is always available. No network, storage, or sensor permissions:
         ROM access is mediated entirely by the Storage Access Framework document
         picker (no broad storage permission needed), and the app collects nothing. -->
    <uses-feature android:name="android.hardware.gamepad" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />
    <!-- v1.8.8 "Atlas" (Workstream G): Android TV / Leanback. `leanback` not-required
         keeps the app installable on phones/tablets while letting it surface on the TV
         home (paired with the LEANBACK_LAUNCHER intent-filter + the TV banner below).
         touchscreen not-required (above) is the hard gate that lets the Play Store list
         it on a d-pad-only TV — a TV box has no touchscreen, so requiring one would
         exclude every TV. The adaptive Compose UI (expanded width) IS the TV UI; there
         is no separate androidx.leanback fragment surface. -->
    <uses-feature android:name="android.software.leanback" android:required="false" />
    <!-- This is NOT a VR / AR app — declare it so the TV / headset stores classify it
         as a standard d-pad app, not an immersive XR experience. -->
    <uses-feature android:name="android.software.vr.mode" android:required="false" />
    <uses-feature android:name="android.hardware.vr.high_performance" android:required="false" />

    <!-- Light haptic tick on on-screen button presses (the virtual controller). -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- RetroAchievements (v1.8.6, opt-in) talks to the RA servers over HTTPS. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:banner="@drawable/tv_banner"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:hardwareAccelerated="true"
        android:resizeableActivity="true"
        android:appCategory="game"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.RustyNES.Splash">

        <!-- v1.8.8 "Atlas" (Workstream A): appCategory="game" opts RustyNES into the
             Android 16 large-screen "games" exception (API 36 otherwise ignores
             screenOrientation/aspect/resizability on screens >= 600 dp). It is a
             safety net only — the app ships real adaptive layouts (Window Size
             Classes) and the wgpu renderer pillarboxes the NES image at any aspect,
             so it lays out correctly with or without the exemption.
             (Workstream K): enableOnBackInvokedCallback="true" turns on the
             predictive-back system animation. Back is dispatched via
             OnBackPressedDispatcher / Compose BackHandler (Activity.onBackPressed is
             no longer called under targetSdk 36 on Android 16). -->


        <!-- v2.0.1 (ADR 0025): the Cast-framework OPTIONS_PROVIDER meta-data and the
             Play Games Services APP_ID meta-data moved to `src/play/AndroidManifest.xml`
             so they merge into the `play` flavor ONLY. The `foss` (F-Droid / sideload)
             merged manifest carries no Play-Services declarations. -->

        <!-- Foldable / large-screen support: the activity is resizeable and
             absorbs the fold/unfold + posture config changes itself (so the
             emulation thread + GL surface survive the transition with no
             restart). `smallestScreenSize`/`screenLayout` cover the cover↔inner
             screen swap on the Z Fold; the Compose layout is responsive (the NES
             image letterboxes into the available space on either display). The
             orientation is left UNLOCKED so the large inner screen can present
             the app in whatever posture the user holds it. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden|uiMode|density|navigation|keyboard"
            android:launchMode="singleTop"
            android:resizeableActivity="true"
            android:supportsPictureInPicture="true">
            <!-- v1.8.8 "Atlas" (Workstream H): Picture-in-Picture. The activity
                 absorbs the PiP enter/exit + resize config changes itself (the
                 emulation thread + GL/Compose surface survive with no restart), so
                 `screenSize|smallestScreenSize|screenLayout|orientation` above
                 already cover the transition. Gameplay keeps running in the PiP
                 window when the user leaves the app (or via the "PiP" control);
                 onPictureInPictureModeChanged hides the HUD/controls in PiP. PiP is
                 API 26+ (== minSdk), so no extra guard is needed at the manifest. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Also launches as a TV/leanback app. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
            <!-- v1.8.8 "Atlas" (Workstream H): static app shortcuts (long-press the
                 launcher icon) — Resume last game / Open ROM / Library. Each deep-
                 links via the DeepLink.EXTRA_ACTION extra. -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- v1.8.8 "Atlas" (Workstream H): "Resume RustyNES" Quick Settings tile.
             Launches the app to the last-played ROM. Requires the
             BIND_QUICK_SETTINGS_TILE permission + the QS_TILE intent-filter. The
             user adds it from the Quick Settings edit tray. -->
        <service
            android:name=".ResumeTileService"
            android:exported="true"
            android:icon="@drawable/ic_tile_resume"
            android:label="@string/tile_resume_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- v1.8.8 "Atlas" (Workstream H): "Resume <last game>" home-screen widget
             (Glance). Shows the last-played game's name and launches into it on tap. -->
        <receiver
            android:name=".ResumeWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_resume_title">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/resume_widget_info" />
        </receiver>
    </application>
</manifest>
