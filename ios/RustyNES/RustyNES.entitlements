<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  RustyNES.entitlements

  v1.9.5 adds the iCloud key-value-store entitlement so the small app config (the
  global Settings scalars: filter, shader params, palette selection, mute, haptics)
  syncs across a user's devices via NSUbiquitousKeyValueStore. NOT save-states or
  ROMs (those stay local in this release).

  MAINTAINER CARRYOVER (cannot be set from Linux / checked-in project alone): the
  iCloud capability + a key-value container must be enabled for the App ID in the
  Apple Developer account and the Xcode target's Signing & Capabilities. Until then
  CloudConfigSync gracefully no-ops (writes stay local). The container id below
  follows the default $(TeamIdentifierPrefix)$(CFBundleIdentifier) convention.

  ROMs remain user-provided through the document picker (no broad file access), and
  the app still collects no data and does no networking beyond this KV sync.
-->
<dict>
	<key>com.apple.developer.ubiquity-kvstore-identifier</key>
	<string>$(TeamIdentifierPrefix)$(CFBundleIdentifier)</string>
</dict>
</plist>
