        "es" : { "stringUnit" : { "state" : "translated", "value" : "Importar" } }
      }
    },
    "Convert an FCEUX .fm2, BizHawk .bk2, Nestopia .fcm, Famtasia .fmv, or VirtuaNES .vmv into a native .rnm for this game." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Convierte un .fm2 de FCEUX, .bk2 de BizHawk, .fcm de Nestopia, .fmv de Famtasia o .vmv de VirtuaNES en un .rnm nativo para este juego." } }
      }
    },
