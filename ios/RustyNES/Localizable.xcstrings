      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Lee o escribe un byte de la RAM de la CPU ($0000-$1FFF). La escritura es única: el juego puede sobrescribirla en el siguiente cuadro." } }
      }
