{
  "sourceLanguage" : "en",
  "version" : "1.0",
  "strings" : {
    "A cycle-accurate NES emulator for iPhone and iPad. RustyNES plays only the ROM files you supply from your own device. No games are bundled or downloaded — you must own the games you play." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Un emulador de NES de precisión de ciclo para iPhone y iPad. RustyNES solo reproduce los archivos ROM que tú proporcionas desde tu propio dispositivo. No se incluyen ni descargan juegos: debes ser propietario de los juegos que utilizas." } }
      }
    },
    "About" : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Acerca de" } }
      }
    },
