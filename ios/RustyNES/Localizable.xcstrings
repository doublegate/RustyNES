    "Return to the game library" : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Volver a la biblioteca de juegos" } }
      }
    },
    "RustyNES is a cycle-accurate Nintendo Entertainment System emulator. It plays only ROM files you supply from your own device. No game content is bundled with or downloaded by the app. You must own the games you play." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "RustyNES es un emulador de Nintendo Entertainment System de precisión de ciclo. Solo reproduce archivos ROM que tú proporcionas desde tu propio dispositivo. La aplicación no incluye ni descarga contenido de juegos. Debes ser propietario de los juegos que utilizas." } }
      }
    },
    "Run a script against the game" : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Ejecuta un script en el juego" } }
      }
    },
    "Save states" : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Estados guardados" } }
      }
    },
    "Screen recording" : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Grabación de pantalla" } }
      }
    },
    "Screen recording isn't available on this device right now." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "La grabación de pantalla no está disponible en este dispositivo en este momento." } }
      }
    },
    "Screen recording isn't available right now." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "La grabación de pantalla no está disponible en este momento." } }
