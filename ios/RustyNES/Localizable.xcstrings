    "Off by default. Signs in to your Apple Game Center account for presence. RustyNES has no leaderboards or achievements of its own — RetroAchievements is the achievement system." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Desactivado por defecto. Inicia sesión en tu cuenta de Apple Game Center para mostrar tu presencia. RustyNES no tiene tablas de clasificación ni logros propios: RetroAchievements es el sistema de logros." } }
      }
    },
    "Open settings" : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Abrir ajustes" } }
      }
    },
    "Open the save-state manager" : {
      "localizations" : {
