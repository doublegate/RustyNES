      }
    },
    "Annotates the disassembly with labels. Parsed on-device; read-only." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Anota el desensamblado con etiquetas. Se analiza en el dispositivo; solo lectura." } }
      }
    },
    "Enable audio depth" : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Activar profundidad de audio" } }
      }
    },
    "Reset to flat" : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Restablecer a plano" } }
      }
    },
    "Audio depth" : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Profundidad de audio" } }
      }
    },
    "Output-only EQ, stereo pan, reverb, and headphone crossfeed. Off by default; flat = unchanged sound." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Ecualizador, paneo estéreo, reverberación y crossfeed para auriculares, solo en la salida. Desactivado por defecto; plano = sonido sin cambios." } }
      }
    },
    "Import a foreign movie" : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Importar una película externa" } }
      }
