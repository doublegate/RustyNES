diff --git a/crates/nes-test-harness/src/accuracy_coin.rs b/crates/nes-test-harness/src/accuracy_coin.rs
index 3c0b31d..867c99d 100644
--- a/crates/nes-test-harness/src/accuracy_coin.rs
+++ b/crates/nes-test-harness/src/accuracy_coin.rs
@@ -270,6 +270,28 @@ pub fn run_battery_with_budget(max_frames: u64) -> BatteryResult {
 /// Panics if the ROM doesn't parse or load.
 #[must_use]
 pub fn run_battery_capturing_ram(max_frames: u64) -> (BatteryResult, Vec<u8>) {
+    // v2.0 Phase 6 (mc-ppu-subpos): allow sweeping the analog `$2001` write
+    // delay + the `$2007` fetch-buffer per-phase offsets at runtime (no
+    // rebuild). `RUSTYNES_MASK_DELAY` sets the PPUMASK write delay (dots);
+    // `RUSTYNES_FETCH_OFF` sets the 8 comma-separated `$2007` fetch offsets.
+    #[cfg(feature = "mc-ppu-subpos")]
+    if let Ok(v) = std::env::var("RUSTYNES_MASK_DELAY") {
+        if let Ok(d) = v.trim().parse::<u8>() {
+            nes_core::nes_ppu::MASK_WRITE_DELAY.store(d, std::sync::atomic::Ordering::Relaxed);
+        }
+    }
+    #[cfg(feature = "ppu-2007-fetch-buffer")]
+    if let Ok(s) = std::env::var("RUSTYNES_2007_OFFSET") {
+        let vals: Vec<i16> = s.split(',').filter_map(|x| x.trim().parse().ok()).collect();
+        for (i, slot) in nes_core::nes_ppu::FETCH_OFFSETS.iter().enumerate() {
+            let v = if vals.len() == 1 {
+                vals[0]
+            } else {
+                *vals.get(i).unwrap_or(&6)
+            };
+            slot.store(v, std::sync::atomic::Ordering::Relaxed);
+        }
+    }
     let bytes = fs::read(rom_path())
         .unwrap_or_else(|e| panic!("read AccuracyCoin.nes: {e} (path={:?})", rom_path()));
     let mut nes = Nes::from_rom(&bytes).expect("parse AccuracyCoin.nes (NROM)");
