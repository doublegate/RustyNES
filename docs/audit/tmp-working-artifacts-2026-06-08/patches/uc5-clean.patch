+    fn arm_dmc_implicit_abort_on_enable(&mut self) {
+        let cuo = self.dmc_cycles_until_output();
+        let get = !self.put_cycle;
+        let in_window = (get && cuo == ABORT_IMPLICIT_CUO_GET)
+            || (!get && cuo == ABORT_IMPLICIT_CUO_PUT);
+        // TriCNES only LATCHES the race here; the 1-cycle abort is actually
+        // raised when the (1-byte non-loop) load DMA completes — see
+        // `complete_dmc_dma{,_before_get_tick}`, which consume this latch.
+        if in_window {
